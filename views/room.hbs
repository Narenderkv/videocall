<!DOCTYPE html>
<html>
<head>
  <title>Video Call - 2 Cameras</title>
  <style>
    video {
      width: 320px;
      height: 240px;
      border: 2px solid #000;
    }
    .video-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }
    .video-box {
      display: flex;
      flex-direction: column; 
      align-items: center;
    }
  </style>
</head>
<body>
  <h2>Multi-User Video Call</h2>
  <div id="user-label" style="font-size: 1.2em; color: #007bff; margin-bottom: 10px;"></div>
  <div class="video-container">
    <div class="video-box" id="local-video-box">
      <h3>Your Camera</h3>
      <video id="localVideo" autoplay muted playsinline></video>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/main.js"></script>
  <script>
    const params = new URLSearchParams(window.location.search);
    const user = params.get('user');
    if (user) {
      document.getElementById('user-label').textContent = `You are: User ${user}`;
    }
  </script>
</body>
</html>
